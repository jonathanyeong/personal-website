---
const { bskyPostId } = Astro.props;
---

<meta data-bsky-post-id={bskyPostId || ''} />

<section class="post__likes" data-bsky-container>
</section>

<script>
  const LIMIT = 55;

  const bskyPostIdElement = document.querySelector("[data-bsky-post-id]") as HTMLElement;
  let bskyPostId: string | undefined = bskyPostIdElement.dataset?.bskyPostId;
  const container = document.querySelector("[data-bsky-container]") as HTMLElement;

  const myDid = "did:plc:sypvcjg7jtlw2ivzumlcxto5";
  const bskyAPI = "https://public.api.bsky.app/xrpc/";
  const getLikesURL = `${bskyAPI}app.bsky.feed.getLikes?limit=${LIMIT}&uri=`;
  const getPostURL = `${bskyAPI}app.bsky.feed.getPosts?uris=`;
  const bskyPostComments = `${bskyAPI}app.bsky.feed.getPostThread?depth=1`;

  function drawHowManyMore(postLikesCount: number, likesActorLength: number, element: HTMLUListElement) {
    if (postLikesCount > LIMIT) {
      const likesMore = document.createElement("li");
      likesMore.classList.add("post__like");
      likesMore.classList.add("post__like--howManyMore");
      likesMore.innerText = `+${postLikesCount - likesActorLength}`;
      element.appendChild(likesMore);
    }
  }

  function drawLikes(likesActors: any[], postLikesCount: number, element: HTMLUListElement) {
    for (const like of likesActors) {
      const likeEl = document.createElement("li");
      likeEl.classList.add("post__like");

      if (like.actor.avatar !== undefined) {
        likeEl.innerHTML = `
        <img class="post__like__avatar"
          src="${like.actor.avatar.replace("avatar", "avatar_thumbnail")}"
          alt="${like.actor.displayName}"
        />`;
      } else {
        likeEl.classList.add("post__like--placeholder");
        likeEl.innerHTML = `
          <span aria-label="${like.actor.displayName}">@</span>
        `;
      }
      element.appendChild(likeEl);
    }

    drawHowManyMore(postLikesCount, likesActors.length, element);
  }

  function atUriToBlueskyUrl(atUri: string, authorHandle: string) {
    const postId = atUri.split('/').pop();
    return `https://bsky.app/profile/${authorHandle}/post/${postId}`;
  }

  function drawComments(comments: any[], element: HTMLUListElement) {
    for (const comment of comments) {
      const commentEl = document.createElement("li");
      commentEl.classList.add("post__comment");
      const postUrl = atUriToBlueskyUrl(comment.post.uri, comment.post.author.handle)
      const commentDateString = comment.post.record.createdAt;
      const commentDate = new Date(commentDateString);
      const formattedCommentDate = commentDate.toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric'
      });
      commentEl.innerHTML = `
        <div class="post__comment__title">
          <div class="post__comment__titleLeft">
            <img
              class="post__comment__avatar"
              src="${comment.post.author.avatar.replace("avatar", "avatar_thumbnail")}"
              alt="${comment.post.author.displayName}"
            />
            <span class="post__comment__titleAuthor">${comment.post.author.displayName}</span>
            <span class="post__comment__titleHandle">@${comment.post.author.handle}</span>
          </div>
          <span class="post__comment__titleDate">${formattedCommentDate}</span>
        </div>
        <p class="post__comment__body">${comment.post.record.text}</p>
        <a class="post__comment__viewCommentLink" href="${postUrl}" target="_blank">View on Bluesky</a>
      `
      element.appendChild(commentEl)
    }
  }

  if (!bskyPostId) {
    const collection = 'app.bsky.feed.post'
    const recordPath = 'embed.external.uri'
    const subject = window.location.href
    const source = encodeURIComponent(`${collection}:${recordPath}`)
    let urlToCall = `https://constellation.microcosm.blue/xrpc/blue.microcosm.links.getBacklinks?subject=${encodeURIComponent(subject)}&source=${source}&limit=1&reverse=true&did=${myDid}`
    const res = await fetch(urlToCall, { headers: { Accept: 'application/json' }})
    const resData = await res.json()
    bskyPostId = resData.records[0]?.rkey
  }

  if (bskyPostId && bskyPostId !== "") {
    const postUri = `at://${myDid}/app.bsky.feed.post/${bskyPostId}`;
    try {
      const bskyPost = await fetch(getPostURL + postUri);
      const bskyPostLikes = await fetch(getLikesURL + postUri);
      const bskyComments = await fetch(bskyPostComments + "&uri=" + postUri)
      const postData = await bskyPost.json();
      const likesData = await bskyPostLikes.json();
      const commentsData = await bskyComments.json();

      const totalLikesCount = postData.posts[0].likeCount;
      if (totalLikesCount > 0 && likesData.likes.length > 0) {
        const h4 = document.createElement('h4')
        h4.classList.add('post__likesTitle')
        h4.innerText = `🦋 ${totalLikesCount} likes on Bluesky`
        container.appendChild(h4)

        const ul = document.createElement('ul')
        ul.classList.add('post__likesList')

        drawLikes(likesData.likes, totalLikesCount, ul);

        container.appendChild(ul)
      }

      const commentTitle = document.createElement('h4')
      commentTitle.classList.add('post__commentsTitle')
      commentTitle.innerText = 'Comments'

      container.appendChild(commentTitle)
      const commentsContainer = document.createElement('ul')
      commentsContainer.classList.add('post__commentsList', 'flow')
      if (commentsData.thread.replies.length > 0) {
        drawComments(commentsData.thread.replies, commentsContainer)
      } else {
        const commentEl = document.createElement("li");
        commentEl.classList.add("post__noComment");
        commentEl.innerHTML = `No comments yet! Be the first to add one.`
        commentsContainer.appendChild(commentEl)
      }

      container.appendChild(commentsContainer)

      const likeLink = document.createElement('a')
      likeLink.classList.add('post__likesCta')
      likeLink.href = `https://bsky.app/profile/jonathanyeong.com/post/${bskyPostId}`
      likeLink.target = '_blank'
      likeLink.innerText = 'Like this post or add your comment on Bluesky'
      container.appendChild(likeLink)
    } catch (error) {
      container.remove();
    }
  }
</script>

<style is:global>
  /* Global style because javascript gets rendered on the client side */
  .post__like__avatar,
  .post__comments__avatar,
  .post__like--placeholder {
    border-radius: 100%;
  }

  img.post__like__avatar,
  img.post__comments__avatar {
    width: auto;
    max-width: 100%;
    height: auto;
  }

  .post__likesList {
    list-style: none;
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    padding: 0;
  }

  .post__like {
    width: 3.5rem;
    aspect-ratio: 1/1;
    margin-right: -0.5rem;
    filter: drop-shadow(rgba(0, 0, 0, 0.25) 0px 2px 2px);
  }

  .post__commentsList {
    --flow-space: var(--space-2xs);
    list-style: none;
    padding: 0;
  }

  .post__comment {
    border-radius: 1rem;
    background-color: var(--color-hero-bg);
    padding: var(--space-m) var(--space-s);
  }

  .post__comment__title {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    gap: var(--space-2xs);
    margin-bottom: var(--space-xs);
    align-items: end;
    justify-content: space-between;
  }

  .post__comment__titleLeft {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    gap: var(--space-2xs);
    align-items: end;
  }

  .post__comment__avatar {
    max-width: var(--space-m);
    border-radius: 100%;
  }

  .post__comment__titleHandle,
  .post__comment__titleDate {
    color: var(--color-hero-text);
  }

  .post__comment__titleDate {
    font-size: 1rem;
    font-style: italic;
  }

  .post__comment__body {
    margin-bottom: var(--space-xs);
  }

  .post__comment__viewCommentLink {
    font-size: 1.1rem;
  }

  .post__comment__titleAuthor {
    font-weight: 700;
  }

  .post__likesTitle,
  .post__commentsTitle {
    margin-block-end: var(--space-s);
  }

  .post__noComment {
    font-style: italic;
  }
</style>
